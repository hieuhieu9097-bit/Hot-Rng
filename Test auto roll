-- Chặn trùng lặp script cũ nếu có chạy trước đó
if _G.HotsRngGui then 
    _G.HotsRngGui:Destroy() 
end

-- Khai báo dịch vụ
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Tìm Remote Event của Game (Mặc định giả định là "RollEvent", hãy đổi lại nếu cần)
local RollRemote = ReplicatedStorage:FindFirstChild("RollEvent") or ReplicatedStorage:WaitForChild("RollEvent", 5)

-- Khởi tạo biến trạng thái
getgenv().AutoRollActive = false

-- ====== TẠO GIAO DIỆN (GUI) ====== --
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "HotsRngMiniGui"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.Parent = game:GetService("CoreGui") or game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui")
_G.HotsRngGui = ScreenGui

-- Khung chính (Main Frame)
local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 160, 0, 90)
MainFrame.Position = UDim2.new(0.5, -80, 0.4, -45) -- Xuất hiện ở giữa màn hình
MainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
MainFrame.BorderSizePixel = 0
MainFrame.Active = true
MainFrame.Parent = ScreenGui

-- Bo góc khung chính
local MainCorner = Instance.new("UICorner")
MainCorner.CornerRadius = UDim.new(0, 10)
MainCorner.Parent = MainFrame

-- Tiêu đề (Title)
local Title = Instance.new("TextLabel")
Title.Name = "Title"
Title.Size = UDim2.new(1, 0, 0, 30)
Title.BackgroundTransparency = 1
Title.Text = "Hots RNG Roll"
Title.TextColor3 = Color3.fromRGB(255, 255, 255)
Title.TextSize = 14
Title.Font = Enum.Font.SourceSansBold
Title.Parent = MainFrame

-- Nút Bật/Tắt Auto Roll
local ToggleBtn = Instance.new("TextButton")
ToggleBtn.Name = "ToggleBtn"
ToggleBtn.Size = UDim2.new(0, 130, 0, 40)
ToggleBtn.Position = UDim2.new(0.5, -65, 0.5, -10)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(220, 50, 50) -- Đỏ khi tắt
ToggleBtn.Text = "Auto Roll: OFF"
ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
ToggleBtn.TextSize = 14
ToggleBtn.Font = Enum.Font.SourceSansBold
ToggleBtn.BorderSizePixel = 0
ToggleBtn.Parent = MainFrame

-- Bo góc nút bấm
local BtnCorner = Instance.new("UICorner")
BtnCorner.CornerRadius = UDim.new(0, 8)
BtnCorner.Parent = ToggleBtn

-- ====== TÍNH NĂNG KÉO DI CHUYỂN GUI (DRAGGABLE) ====== --
local dragging, dragInput, dragStart, startPos

local function update(input)
    local delta = input.Position - dragStart
    MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

MainFrame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

MainFrame.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        update(input)
    end
end)

-- ====== XỬ LÝ VÒNG LẶP AUTO ROLL ====== --
local function startRollLoop()
    task.spawn(function()
        while getgenv().AutoRollActive do
            if RollRemote then
                RollRemote:FireServer()
            end
            task.wait() -- Tốc độ siêu nhanh, tự điều chỉnh nếu bị kick
        end
    end)
end

-- Sự kiện click nút
ToggleBtn.MouseButton1Click:Connect(function()
    getgenv().AutoRollActive = not getgenv().AutoRollActive
    
    if getgenv().AutoRollActive then
        -- Khi bật: Đổi nút sang màu xanh lá
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 180, 50)
        ToggleBtn.Text = "Auto Roll: ON"
        startRollLoop()
    else
        -- Khi tắt: Đổi nút về màu đỏ
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(220, 50, 50)
        ToggleBtn.Text = "Auto Roll: OFF"
    end
end)

print("✅ Đã tải thành công GUI Auto Roll thử nghiệm!")
