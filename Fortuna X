-- [[ FORTUNA X - HOT RNG SCRIPT ]]
-- UI Framework: Orion Library (Thân thiện nhất với Delta Mobile)
-- Optimized for Mobile Executors

-- 0. Dọn dẹp GUI cũ nếu có để tránh kẹt menu
if game:GetService("CoreGui"):FindFirstChild("Orion") then
    game:GetService("CoreGui").Orion:Destroy()
end

-- 1. KHỞI TẠO ORION LIBRARY
local OrionLib = loadstring(game:HttpGet(('https://raw.githubusercontent.com/shlexware/Orion/main/source.lua')))()

-- Tạo Cửa sổ chính (Tự động tạo nút ẩn/hiện hình tròn trên màn hình điện thoại)
local Window = OrionLib:MakeWindow({
    Name = "Fortuna X | Hot RNG", 
    HidePremium = true, 
    SaveConfig = false, 
    IntroText = "Loading Fortuna X...",
    IntroToggle = true
})

-- Các biến trạng thái hoạt động (Toggles)
local AutoCollectClovers = false
local AutoPray = false

-- Lấy thông tin người chơi
local Player = game.Players.LocalPlayer
local function getCharacter()
    return Player.Character or Player.CharacterAdded:Wait()
end

local function getRoot()
    local char = getCharacter()
    return char:WaitForChild("HumanoidRootPart")
end

-- ==========================================
-- CẤU HÌNH CÁC TÁB & CHỨC NĂNG (ORION SYNTAX)
-- ==========================================

local MainTab = Window:MakeTab({
	Name = "Main Features",
	Icon = "rbxassetid://4483345998",
	PremiumOnly = false
})

-- CHỨC NĂNG 1: AUTO COLLECT CLOVERS
MainTab:AddToggle({
	Name = "Auto Collect Clovers",
	Default = false,
	Callback = function(Value)
		AutoCollectClovers = Value
        if AutoCollectClovers then
            task.spawn(function()
                while AutoCollectClovers do
                    task.wait(0.1) -- Giữ delay nhỏ để máy không bị quá nhiệt
                    
                    local cloversFolder = workspace:FindFirstChild("Clovers")
                    if cloversFolder then
                        local clovers = cloversFolder:GetChildren()
                        
                        for _, clover in ipairs(clovers) do
                            if not AutoCollectClovers then break end
                            
                            local targetCFrame = nil
                            if clover:IsA("BasePart") then
                                targetCFrame = clover.CFrame
                            elseif clover:IsA("Model") and clover.PrimaryPart then
                                targetCFrame = clover.PrimaryPart.CFrame
                            elseif clover:IsA("Model") and clover:FindFirstChildWhichIsA("BasePart") then
                                targetCFrame = clover:FindFirstChildWhichIsA("BasePart").CFrame
                            end
                            
                            -- Dịch chuyển tức thời
                            if targetCFrame then
                                pcall(function()
                                    getRoot().CFrame = targetCFrame
                                end)
                                task.wait(0.2) -- Đợi game đồng bộ dữ liệu nhận Clover
                            end
                        end
                    end
                end
            end)
        end
	end
})

-- CHỨC NĂNG 2: AUTO PRAY
MainTab:AddToggle({
	Name = "Auto Pray",
	Default = false,
	Callback = function(Value)
		AutoPray = Value
        if AutoPray then
            task.spawn(function()
                while AutoPray do
                    -- Tìm kiếm đệ quy Praypart trong Workspace
                    local prayPart = workspace:FindFirstChild("Praypart", true)
                    
                    if prayPart and prayPart:IsA("BasePart") then
                        -- 1. Teleport lập tức tới Praypart
                        pcall(function()
                            getRoot().CFrame = prayPart.CFrame + Vector3.new(0, 3, 0) -- Cao hơn 3 block tránh kẹt sàn
                        end)
                        task.wait(0.5) -- Đợi nhân vật ổn định vị trí
                        
                        -- 2. Tìm và kích hoạt ProximityPrompt để tương tác
                        local prompt = prayPart:FindFirstChildWhichIsA("ProximityPrompt") or prayPart:FindFirstChild("ProximityPrompt", true)
                        if prompt then
                            pcall(function()
                                fireproximityprompt(prompt)
                            end)
                        end
                        
                        -- 3. Vòng lặp đếm ngược 330 giây (có thể ngắt ngay khi tắt toggle)
                        for i = 1, 330 do
                            if not AutoPray then break end
                            task.wait(1)
                        end
                    else
                        -- Nếu không thấy Part, đợi 5 giây rồi tìm lại
                        task.wait(5)
                    end
                end
            end)
        end
	end
})

-- BẢNG THÔNG TIN PHỤ TRONG MENU
local InfoTab = Window:MakeTab({
	Name = "Credits/Status",
	Icon = "rbxassetid://4483345998",
	PremiumOnly = false
})

InfoTab:AddLabel("Status: Fortuna X Active")
InfoTab:AddLabel("UI Framework: Orion UI (Delta Mobile Friendly)")

-- KÍCH HOẠT HỆ THỐNG
OrionLib:Init()
