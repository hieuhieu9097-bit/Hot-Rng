-- CHỨC NĂNG 2: AUTO PRAY
MainTab:AddToggle({
	Name = "Auto Pray",
	Default = false,
	Callback = function(Value)
		AutoPray = Value
        if AutoPray then
            task.spawn(function()
                while AutoPray do
                    -- Tìm kiếm đệ quy Praypart trong Workspace
                    local prayPart = workspace:FindFirstChild("Praypart", true)
                    
                    if prayPart and prayPart:IsA("BasePart") then
                        -- 1. Teleport lập tức tới Praypart
                        pcall(function()
                            getRoot().CFrame = prayPart.CFrame + Vector3.new(0, 3, 0) -- Cao hơn 3 block tránh kẹt sàn
                        end)
                        task.wait(0.5) -- Đợi nhân vật ổn định vị trí
                        
                        -- 2. Tìm và kích hoạt ProximityPrompt để tương tác
                        local prompt = prayPart:FindFirstChildWhichIsA("ProximityPrompt") or prayPart:FindFirstChild("ProximityPrompt", true)
                        if prompt then
                            pcall(function()
                                fireproximityprompt(prompt)
                            end)
                        end
                        
                        -- 3. Vòng lặp đếm ngược 330 giây (có thể ngắt ngay khi tắt toggle)
                        for i = 1, 330 do
                            if not AutoPray then break end
                            task.wait(1)
                        end
                    else
                        -- Nếu không thấy Part, đợi 5 giây rồi tìm lại
                        task.wait(5)
                    end
                end
            end)
        end
	end
})

