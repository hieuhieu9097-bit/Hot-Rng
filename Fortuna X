-- [[ FORTUNA X - HOT RNG SCRIPT ]]
-- UI Framework: Obsidian UI (Modded Version)
-- Optimized for Mobile Executors

-- 1. KHỞI TẠO OBSIDIAN UI LIBRARY
local Obsidian = loadstring(game:HttpGet("https://raw.githubusercontent.com/tanhoangviet/Obsidian-UI-Modded/main/source.lua"))()

-- Tạo Cửa sổ giao diện chính
local Window = Obsidian:CreateWindow({
    Title = "Fortuna X | Hot RNG",
    Theme = "Dark", -- Giao diện tối giúp dịu mắt và đỡ lag mobile
    Size = UDim2.new(0, 340, 0, 240) -- Kích thước vừa vặn cho màn hình điện thoại
})

-- Tạo một Tab chính chứa các tính năng
local MainTab = Window:CreateTab("Main")

-- Các biến trạng thái hoạt động (Toggles)
local AutoCollectClovers = false
local AutoPray = false

-- Lấy thông tin người chơi
local Player = game.Players.LocalPlayer
local function getCharacter()
    return Player.Character or Player.CharacterAdded:Wait()
end

local function getRoot()
    local char = getCharacter()
    return char:WaitForChild("HumanoidRootPart")
end

-- ==========================================
-- CÀI ĐẶT CÁC CHỨC NĂNG (OBSIDIAN SYNTAX)
-- ==========================================

-- CHỨC NĂNG 1: AUTO COLLECT CLOVERS
MainTab:CreateToggle({
    Title = "Auto Collect Clovers",
    Default = false,
    Callback = function(Value)
        AutoCollectClovers = Value
        if AutoCollectClovers then
            task.spawn(function()
                while AutoCollectClovers do
                    task.wait(0.1)
                    
                    local cloversFolder = workspace:FindFirstChild("Clovers")
                    if cloversFolder then
                        local clovers = cloversFolder:GetChildren()
                        
                        for _, clover in ipairs(clovers) do
                            if AutoCollectClovers then
                                local targetCFrame = nil
                                if clover:IsA("BasePart") then
                                    targetCFrame = clover.CFrame
                                elseif clover:IsA("Model") and clover.PrimaryPart then
                                    targetCFrame = clover.PrimaryPart.CFrame
                                elseif clover:IsA("Model") and clover:FindFirstChildWhichIsA("BasePart") then
                                    targetCFrame = clover:FindFirstChildWhichIsA("BasePart").CFrame
                                end
                                
                                -- Dịch chuyển tức thời
                                if targetCFrame then
                                    pcall(function()
                                        getRoot().CFrame = targetCFrame
                                    end)
                                    task.wait(0.2) -- Khựng lại một chút để game kịp lưu dữ liệu nhận Clover
                                end
                            else
                                break
                            end
                        end
                    end
                end
            end)
        end
    end
})

-- CHỨC NĂNG 2: AUTO PRAY
MainTab:CreateToggle({
    Title = "Auto Pray",
    Default = false,
    Callback = function(Value)
        AutoPray = Value
        if AutoPray then
            task.spawn(function()
                while AutoPray do
                    -- Tìm kiếm sâu (quét đệ quy) trong Workspace để tìm Praypart
                    local prayPart = workspace:FindFirstChild("Praypart", true)
                    
                    if prayPart and prayPart:IsA("BasePart") then
                        -- 1. Teleport lập tức tới Praypart
                        pcall(function()
                            getRoot().CFrame = prayPart.CFrame + Vector3.new(0, 3, 0) -- Cao hơn 3 block tránh kẹt đất
                        end)
                        task.wait(0.5) -- Đợi nhân vật ổn định vị trí
                        
                        -- 2. Tìm và kích hoạt ProximityPrompt
                        local prompt = prayPart:FindFirstChildWhichIsA("ProximityPrompt") or prayPart:FindFirstChild("ProximityPrompt", true)
                        if prompt then
                            pcall(function()
                                fireproximityprompt(prompt) -- Kích hoạt nút tương tác
                            end)
                        end
                        
                        -- 3. Đếm ngược 330 giây (có thể ngắt ngay khi tắt toggle)
                        for i = 1, 330 do
                            if not AutoPray then break end
                            task.wait(1)
                        end
                    else
                        -- Nếu không thấy Part, đợi 5 giây rồi tìm lại để tránh sập script
                        task.wait(5)
                    end
                end
            end)
        end
    end
})

-- Thêm một nhãn thông tin nhỏ phía dưới giao diện
MainTab:CreateLabel({
    Title = "Status: Fortuna X Active!",
    Style = "Success" -- Hiển thị màu xanh lá báo hiệu hoạt động tốt
})
