-- NÚT 1: AUTO COLLECT CLOVERS
ToggleCloverBtn.Name = "ToggleCloverBtn"
ToggleCloverBtn.Parent = MainFrame
ToggleCloverBtn.BackgroundColor3 = Color3.fromRGB(180, 50, 50) -- Màu đỏ (OFF)
ToggleCloverBtn.Position = UDim2.new(0.05, 0, 0.25, 0)
