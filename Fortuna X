-- CHỨC NĂNG 1: AUTO COLLECT CLOVERS
LeftGroupBox:AddToggle("CloverToggle", {
	Text = "Auto Collect Clovers",
	Default = false,
	Tooltip = "Tự động dịch chuyển nhặt toàn bộ vật phẩm trong folder Clovers",
})

-- Xử lý Logic cho Auto Collect Clovers bằng :OnChanged đúng khuyến nghị của thư viện
Library.Toggles.CloverToggle:OnChanged(function()
    local state = Library.Toggles.CloverToggle.Value
    if state then
        task.spawn(function()
            while Library.Toggles.CloverToggle.Value do
                task.wait(0.1)
                
                local cloversFolder = workspace:FindFirstChild("Clovers")
                if cloversFolder then
                    local clovers = cloversFolder:GetChildren()
                    
                    for _, clover in ipairs(clovers) do
                        if not Library.Toggles.CloverToggle.Value then break end
                        
                        local targetCFrame = nil
                        if clover:IsA("BasePart") then
                            targetCFrame = clover.CFrame
                        elseif clover:IsA("Model") and clover.PrimaryPart then
                            targetCFrame = clover.PrimaryPart.CFrame
                        elseif clover:IsA("Model") and clover:FindFirstChildWhichIsA("BasePart") then
                            targetCFrame = clover:FindFirstChildWhichIsA("BasePart").CFrame
                        end
                        
                        -- Thực hiện dịch chuyển tức thời (Instant Teleport)
                        if targetCFrame then
                            pcall(function()
                                getRoot().CFrame = targetCFrame
                            end)
                            task.wait(0.2) -- Khựng lại một chút để game đồng bộ dữ liệu nhận Clover
                        end
                    end
                end
            end
        end)
    end
end)

-- CHỨC NĂNG 2: AUTO PRAY
LeftGroupBox:AddToggle("PrayToggle", {
	Text = "Auto Pray",
	Default = false,
	Tooltip = "Teleport tới Praypart, tự bấm nút tương tác và tự động chờ 330 giây",
})

-- Xử lý Logic cho Auto Pray bằng :OnChanged
Library.Toggles.PrayToggle:OnChanged(function()
    local state = Library.Toggles.PrayToggle.Value
    if state then
        task.spawn(function()
            while Library.Toggles.PrayToggle.Value do
                -- Tìm kiếm sâu vật thể có tên Praypart trong Workspace
                local prayPart = workspace:FindFirstChild("Praypart", true)
                
                if prayPart and prayPart:IsA("BasePart") then
                    -- 1. Teleport lập tức tới vị trí Praypart
                    pcall(function()
                        getRoot().CFrame = prayPart.CFrame + Vector3.new(0, 3, 0) -- Cao hơn 3 block tránh kẹt đất
                    end)
                    task.wait(0.5) -- Đợi nhân vật ổn định vị trí sau khi dịch chuyển
                    
                    -- 2. Tìm và kích hoạt ProximityPrompt để tương tác cầu nguyện
                    local prompt = prayPart:FindFirstChildWhichIsA("ProximityPrompt") or prayPart:FindFirstChild("ProximityPrompt", true)
                    if prompt then
                        pcall(function()
                            fireproximityprompt(prompt)
                        end)
                    end
                    
                    -- 3. Vòng lặp đếm ngược 330 giây (Có thể ngắt ngay lập tức khi tắt Toggle)
                    for i = 1, 330 do
                        if not Library.Toggles.PrayToggle.Value then break end
                        task.wait(1)
                    end
                else
                    -- Nếu không tìm thấy Praypart trên bản đồ, đợi 5 giây rồi quét lại
                    task.wait(5)
                end
            end
        end)
    end
end)

