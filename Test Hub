local AutoCollectClovers = false
local AutoPray = false
local AutoCollectEgg = false
local CollectedEggs = {}

local Player = game.Players.LocalPlayer
local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

local function deepSearch(root, name)
    local found = root:FindFirstChild(name, true)
    if found then return found end
    for _, child in ipairs(root:GetChildren()) do
        local s, res = pcall(function() return child:FindFirstChild(name, true) end)
        if s and res then return res end
        if child:IsA("Folder") or child:IsA("Model") or child:IsA("Configuration") then
            local deepRes = deepSearch(child, name)
            if deepRes then return deepRes end
        end
    end
    return nil
end

local function scanAllWorkspaceForEggs()
    local results = {}
    for _, child in ipairs(workspace:GetChildren()) do
        for eggName, _ in pairs(eggDisplayNames) do
            if child.Name == eggName then
                table.insert(results, child)
            end
        end
        local s, desc = pcall(function() return child:GetDescendants() end)
        if s and desc then
            for _, d in ipairs(desc) do
                if eggDisplayNames[d.Name] then
                    table.insert(results, d)
                end
            end
        end
    end
    return results
end

local function createToraToggle(name, text, yOffset, callback)
    local Button = Instance.new("TextButton")
    Button.Name = name
    Button.Parent = LeftColumn
    Button.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
    Button.Position = UDim2.new(0, 0, 0, yOffset)
    Button.Size = UDim2.new(1, 0, 0, 26)
    Button.Font = Enum.Font.GothamBold
    Button.Text = text .. " : [OFF]"
    Button.TextColor3 = Color3.fromRGB(150, 150, 155)
    Button.TextSize = 9
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 5)
    BtnCorner.Parent = Button
    
    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Color = Color3.fromRGB(40, 40, 45)
    BtnStroke.Thickness = 1
    BtnStroke.Parent = Button

    local active = false
    Button.MouseButton1Click:Connect(function()
        active = not active
        if active then
            Button.BackgroundColor3 = Color3.fromRGB(45, 45, 50)
            Button.TextColor3 = Color3.fromRGB(255, 255, 255)
            BtnStroke.Color = Color3.fromRGB(140, 140, 145)
            Button.Text = text .. " : [ON]"
        else
            Button.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
            Button.TextColor3 = Color3.fromRGB(150, 150, 155)
            BtnStroke.Color = Color3.fromRGB(40, 40, 45)
            Button.Text = text .. " : [OFF]"
        end
        callback(active)
    end)
end

createToraToggle("CloverBtn", "Auto Clovers", 24, function(state)
    AutoCollectClovers = state
    if AutoCollectClovers then
        task.spawn(function()
            while AutoCollectClovers do
                task.wait(0.1)
                local folder = workspace:FindFirstChild("Clovers")
                if folder and getRoot() then
                    for _, clover in ipairs(folder:GetChildren()) do
                        if not AutoCollectClovers then break end
                        local cf = clover:IsA("BasePart") and clover.CFrame or clover:IsA("Model") and (clover.PrimaryPart and clover.PrimaryPart.CFrame or clover:FindFirstChildWhichIsA("BasePart") and clover:FindFirstChildWhichIsA("BasePart").CFrame)
                        if cf then
                            pcall(function() getRoot().CFrame = cf end)
                            task.wait(0.2)
                        end
                    end
                end
            end
        end)
    end
end)

createToraToggle("PrayBtn", "Auto Pray", 55, function(state)
    AutoPray = state
    if AutoPray then
        task.spawn(function()
            while AutoPray do
                StatusLog.Text = "Status: Scanning PrayPart..."
                StatusLog.TextColor3 = Color3.fromRGB(200, 200, 205)
                local prayPart = deepSearch(workspace, "PrayPart")
                if prayPart and prayPart:IsA("BasePart") and getRoot() then
                    StatusLog.Text = "Status: Found! Teleporting..."
                    StatusLog.TextColor3 = Color3.fromRGB(240, 240, 245)
                    pcall(function() getRoot().CFrame = prayPart.CFrame + Vector3.new(0, 3, 0) end)
                    task.wait(0.5)
                    StatusLog.Text = "Status: Praying..."
                    local prompt = prayPart:FindFirstChildWhichIsA("ProximityPrompt") or prayPart:FindFirstChild("ProximityPrompt", true)
                    if prompt then
                        pcall(function() fireproximityprompt(prompt) end)
                        StatusLog.TextColor3 = Color3.fromRGB(255, 255, 255)
                        for i = 330, 1, -1 do
                            if not AutoPray then break end
                            local minutes = math.floor(i / 60)
                            local seconds = i % 60
                            StatusLog.Text = "Status: " .. minutes .. "m" .. seconds .. "s"
                            task.wait(1)
                        end
                    else
                        StatusLog.Text = "Status: Error - No Prompt"
                        StatusLog.TextColor3 = Color3.fromRGB(180, 70, 70)
                        task.wait(4)
                    end
                else
                    StatusLog.Text = "Status: Retrying Scan..."
                    StatusLog.TextColor3 = Color3.fromRGB(180, 70, 70)
                    task.wait(2)
                end
            end
            StatusLog.Text = "Status: Disabled"
            StatusLog.TextColor3 = Color3.fromRGB(150, 150, 155)
        end)
    end
end)

createToraToggle("EggBtn", "Auto Egg", 86, function(state)
    AutoCollectEgg = state
    if AutoCollectEgg then
        task.spawn(function()
            while AutoCollectEgg do
                task.wait(0.5)
                if getRoot() then
                    local allEggs = scanAllWorkspaceForEggs()
                    for _, obj in ipairs(allEggs) do
                        if not AutoCollectEgg then break end
                        if obj:IsA("BasePart") and eggDisplayNames[obj.Name] and selectedEggs[obj.Name] then
                            if not CollectedEggs[obj] then
                                StatusLog.Text = "Status: Found " .. obj.Name .. "!"
                                StatusLog.TextColor3 = Color3.fromRGB(200, 200, 205)
                                pcall(function() getRoot().CFrame = obj.CFrame + Vector3.new(0, 2, 0) end)
                                task.wait(0.4)
                                local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt") or obj:FindFirstChild("ProximityPrompt", true)
                                if prompt then
                                    pcall(function() fireproximityprompt(prompt) end)
                                    CollectedEggs[obj] = true
                                    
                                    local label = statusLabels[obj.Name]
                                    if label then
                                        label.Text = "Picked up"
                                        label.TextColor3 = Color3.fromRGB(255, 255, 255)
                                    end
                                    
                                    StatusLog.Text = "Status: Collected " .. obj.Name
                                    StatusLog.TextColor3 = Color3.fromRGB(240, 240, 245)
                                    
                                    task.spawn(function()
                                        task.wait(1800)
                                        if CollectedEggs[obj] then
                                            CollectedEggs[obj] = nil
                                            if label and AutoCollectEgg then
                                                if selectedEggs[obj.Name] then
                                                    label.Text = "Waiting..."
                                                    label.TextColor3 = Color3.fromRGB(180, 130, 70)
                                                else
                                                    label.Text = "Ignored"
                                                    label.TextColor3 = Color3.fromRGB(90, 90, 95)
                                                end
                                            end
                                        end
                                    end)
                                    task.wait(1)
                                end
                            end
                        end
                    end
                end
            end
        end)
    else
        CollectedEggs = {}
        for name, label in pairs(statusLabels) do
            if selectedEggs[name] then
                label.Text = "Waiting..."
                label.TextColor3 = Color3.fromRGB(180, 130, 70)
            else
                label.Text = "Ignored"
                label.TextColor3 = Color3.fromRGB(90, 90, 95)
            end
        end
    end
end)

