local Player = game.Players.LocalPlayer
local function getRoot()
    return Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
end

local function createToraToggle(name, text, pos, callback)
    local Button = Instance.new("TextButton")
    Button.Name = name
    Button.Parent = MainFrame
    Button.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    Button.Position = pos
    Button.Size = UDim2.new(0.9, 0, 0, 32)
    Button.Font = Enum.Font.GothamBold
    Button.Text = text .. " : [OFF]"
    Button.TextColor3 = Color3.fromRGB(200, 200, 200)
    Button.TextSize = 11
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 6)
    BtnCorner.Parent = Button
    
    local BtnStroke = Instance.new("UIStroke")
    BtnStroke.Color = Color3.fromRGB(40, 40, 50)
    BtnStroke.Thickness = 1
    BtnStroke.Parent = Button

    local active = false
    Button.MouseButton1Click:Connect(function()
        active = not active
        if active then
            Button.BackgroundColor3 = Color3.fromRGB(0, 50, 100)
            Button.TextColor3 = Color3.fromRGB(0, 200, 255)
            BtnStroke.Color = Color3.fromRGB(0, 170, 255)
            Button.Text = text .. " : [ON]"
        else
            Button.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
            Button.TextColor3 = Color3.fromRGB(200, 200, 200)
            BtnStroke.Color = Color3.fromRGB(40, 40, 50)
            Button.Text = text .. " : [OFF]"
        end
        callback(active)
    end)
end

createToraToggle("CloverBtn", "Auto Collect Clovers", UDim2.new(0.05, 0, 0.11, 0), function(state)
    AutoCollectClovers = state
    if AutoCollectClovers then
        task.spawn(function()
            while AutoCollectClovers do
                task.wait(0.1)
                local folder = workspace:FindFirstChild("Clovers")
                if folder and getRoot() then
                    for _, clover in ipairs(folder:GetChildren()) do
                        if not AutoCollectClovers then break end
                        local cf = clover:IsA("BasePart") and clover.CFrame or clover:IsA("Model") and (clover.PrimaryPart and clover.PrimaryPart.CFrame or clover:FindFirstChildWhichIsA("BasePart") and clover:FindFirstChildWhichIsA("BasePart").CFrame)
                        if cf then
                            pcall(function() getRoot().CFrame = cf end)
                            task.wait(0.2)
                        end
                    end
                end
            end
        end)
    end
end)

createToraToggle("PrayBtn", "Auto Pray", UDim2.new(0.05, 0, 0.20, 0), function(state)
    AutoPray = state
    if AutoPray then
        task.spawn(function()
            while AutoPray do
                StatusLog.Text = "Status: Scanning PrayPart..."
                StatusLog.TextColor3 = Color3.fromRGB(255, 180, 0)
                local prayPart = workspace:FindFirstChild("PrayPart", true)
                if prayPart and prayPart:IsA("BasePart") and getRoot() then
                    StatusLog.Text = "Status: Found! Teleporting..."
                    StatusLog.TextColor3 = Color3.fromRGB(0, 200, 255)
                    pcall(function() getRoot().CFrame = prayPart.CFrame + Vector3.new(0, 3, 0) end)
                    task.wait(0.5)
                    StatusLog.Text = "Status: Praying..."
                    local prompt = prayPart:FindFirstChildWhichIsA("ProximityPrompt") or prayPart:FindFirstChild("ProximityPrompt", true)
                    if prompt then
                        pcall(function() fireproximityprompt(prompt) end)
                        StatusLog.TextColor3 = Color3.fromRGB(0, 255, 150)
                        for i = 330, 1, -1 do
                            if not AutoPray then break end
                            local minutes = math.floor(i / 60)
                            local seconds = i % 60
                            StatusLog.Text = "Status: " .. minutes .. "m" .. seconds .. "s"
                            task.wait(1)
                        end
                    else
                        StatusLog.Text = "Status: Error - No Prompt"
                        StatusLog.TextColor3 = Color3.fromRGB(255, 50, 50)
                        task.wait(4)
                    end
                else
                    StatusLog.Text = "Status: Error - Part Not Found"
                    StatusLog.TextColor3 = Color3.fromRGB(255, 50, 50)
                    task.wait(5)
                end
            end
            StatusLog.Text = "Status: Disabled"
            StatusLog.TextColor3 = Color3.fromRGB(0, 255, 150)
        end)
    end
end)

createToraToggle("EggBtn", "Auto Collect Egg", UDim2.new(0.05, 0, 0.29, 0), function(state)
    AutoCollectEgg = state
    if AutoCollectEgg then
        task.spawn(function()
            while AutoCollectEgg do
                task.wait(0.5)
                if getRoot() then
                    for _, obj in ipairs(workspace:GetDescendants()) do
                        if not AutoCollectEgg then break end
                        if obj:IsA("BasePart") and eggDisplayNames[obj.Name] then
                            if not CollectedEggs[obj] then
                                StatusLog.Text = "Status: Found " .. obj.Name .. "!"
                                StatusLog.TextColor3 = Color3.fromRGB(0, 200, 255)
                                pcall(function() getRoot().CFrame = obj.CFrame + Vector3.new(0, 2, 0) end)
                                task.wait(0.4)
                                local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt") or obj:FindFirstChild("ProximityPrompt", true)
                                if prompt then
                                    pcall(function() fireproximityprompt(prompt) end)
                                    CollectedEggs[obj] = true
                                    
                                    local label = eggLabels[obj.Name]
                                    if label then
                                        label.Text = " " .. eggDisplayNames[obj.Name] .. ": Picked up"
                                        label.TextColor3 = Color3.fromRGB(75, 255, 75)
                                    end
                                    
                                    StatusLog.Text = "Status: Collected " .. obj.Name
                                    StatusLog.TextColor3 = Color3.fromRGB(0, 255, 150)
                                    task.wait(1)
                                end
                            end
                        end
                    end
                end
            end
        end)
    else
        CollectedEggs = {}
        for name, label in pairs(eggLabels) do
            label.Text = " " .. eggDisplayNames[name] .. ": Not yet picked up"
            label.TextColor3 = Color3.fromRGB(255, 75, 75)
        end
    end
end)

